generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id       String    @id @default(uuid())
  name     String
  imageUrl String
  rating   Float
  category String
  products Product[]
}

model Product {
  id         String      @id @default(uuid())
  shopId     String
  shop       Shop        @relation(fields: [shopId], references: [id])
  name       String
  imageUrl   String
  price      Float
  category   String
  orderItems OrderItem[]
}

model Order {
  id         String      @id @default(uuid())
  name       String
  email      String
  phone      String
  address    String
  totalPrice Float
  couponCode String?
  discount   Float       @default(0)
  createdAt  DateTime    @default(now())
  items      OrderItem[]
}

model OrderItem {
  id           String  @id @default(uuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id])
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  quantity     Int
  priceAtOrder Float
}

model Coupon {
  id              String  @id @default(uuid())
  code            String  @unique
  name            String
  imageUrl        String
  discountPercent Float
  isActive        Boolean @default(true)
}
